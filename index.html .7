<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>مشروع أُفق | Horizon - ترويج السياحة المستدامة 2026</title>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700;900&family=Amiri:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary-dark: #0b2318;
            --primary-mid: #163d28;
            --gold: #c8a45a;
            --gold-light: #e0c07a;
            --gold-dim: rgba(200,164,90,0.15);
            --off-white: #f9f7f2;
            --text-dark: #1a1a1a;
            --text-mid: #444;
            --gray-bg: #f2f4f0;
            --success: #27ae60;
            --warning: #e59c12;
            --error: #c0392b;
            --card-shadow: 0 20px 60px rgba(11,35,24,0.14);
            --radius: 20px;
        }

        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        html { scroll-behavior: smooth; }

        body {
            font-family: 'Cairo', sans-serif;
            background: var(--off-white);
            color: var(--text-dark);
            line-height: 1.8;
            overflow-x: hidden;
        }

        /* ======= SCROLL BAR ======= */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: var(--primary-dark); }
        ::-webkit-scrollbar-thumb { background: var(--gold); border-radius: 3px; }

        /* ======= NAVBAR ======= */
        nav {
            background: linear-gradient(135deg, var(--primary-dark) 0%, var(--primary-mid) 100%);
            padding: 1rem 2.5rem;
            box-shadow: 0 4px 20px rgba(0,0,0,0.25);
            position: sticky;
            top: 0;
            z-index: 1000;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 2px solid var(--gold-dim);
        }

        .nav-logo {
            display: flex;
            flex-direction: column;
            gap: 0.15rem;
            text-decoration: none;
        }

        .logo-text {
            font-family: 'Amiri', serif;
            font-size: 1.9rem;
            color: var(--gold);
            line-height: 1;
        }

        .logo-subtitle {
            font-size: 0.65rem;
            letter-spacing: 3px;
            color: rgba(255,255,255,0.6);
            text-transform: uppercase;
        }

        .nav-menu {
            display: flex;
            list-style: none;
            gap: 0.5rem;
        }

        .nav-link {
            color: rgba(255,255,255,0.85);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 0.4rem;
            padding: 0.5rem 1.1rem;
            border-radius: 50px;
            font-size: 0.95rem;
            transition: all 0.25s ease;
            border: 1px solid transparent;
        }

        .nav-link:hover, .nav-link.active {
            background: var(--gold-dim);
            border-color: var(--gold);
            color: var(--gold);
            transform: translateY(-1px);
        }

        .menu-icon {
            display: none;
            font-size: 1.7rem;
            color: white;
            cursor: pointer;
            background: none;
            border: none;
            padding: 0.3rem;
        }

        /* ======= HERO HEADER ======= */
        header {
            min-height: 70vh;
            background:
                linear-gradient(to bottom, rgba(11,35,24,0.78) 0%, rgba(11,35,24,0.55) 60%, rgba(11,35,24,0.85) 100%),
                url('https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?q=80&w=2000') center/cover no-repeat;
            background-attachment: fixed;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            color: white;
            text-align: center;
            border-bottom: 5px solid var(--gold);
            position: relative;
            overflow: hidden;
            padding: 4rem 2rem;
        }

        header::after {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse at 50% 80%, rgba(200,164,90,0.12) 0%, transparent 65%);
            pointer-events: none;
        }

        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: var(--gold-dim);
            border: 1px solid var(--gold);
            color: var(--gold);
            padding: 6px 18px;
            border-radius: 50px;
            font-size: 0.85rem;
            font-weight: 600;
            letter-spacing: 1px;
            margin-bottom: 1.5rem;
            position: relative;
            z-index: 2;
            animation: fadeInDown 0.6s ease both;
        }

        header h1 {
            font-family: 'Amiri', serif;
            font-size: clamp(3rem, 8vw, 6rem);
            font-weight: 700;
            position: relative;
            z-index: 2;
            text-shadow: 0 4px 20px rgba(0,0,0,0.4);
            animation: fadeInDown 0.7s ease 0.1s both;
            line-height: 1.1;
        }

        header h1 span {
            color: var(--gold);
        }

        .hero-divider {
            width: 120px;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--gold), transparent);
            margin: 1.2rem auto;
            position: relative;
            z-index: 2;
            animation: expandW 0.8s ease 0.4s both;
        }

        @keyframes expandW {
            from { width: 0; opacity: 0; }
            to { width: 120px; opacity: 1; }
        }

        header p {
            font-size: clamp(1rem, 2.5vw, 1.35rem);
            font-weight: 300;
            opacity: 0.9;
            max-width: 600px;
            position: relative;
            z-index: 2;
            animation: fadeInUp 0.7s ease 0.3s both;
        }

        .hero-cta {
            display: flex;
            gap: 1rem;
            margin-top: 2rem;
            position: relative;
            z-index: 2;
            animation: fadeInUp 0.7s ease 0.5s both;
            flex-wrap: wrap;
            justify-content: center;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--gold) 0%, var(--gold-light) 100%);
            color: var(--primary-dark);
            text-decoration: none;
            padding: 0.85rem 2rem;
            border-radius: 50px;
            font-weight: 700;
            font-size: 1rem;
            transition: all 0.3s ease;
            border: none;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            box-shadow: 0 8px 25px rgba(200,164,90,0.35);
        }

        .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 35px rgba(200,164,90,0.5);
        }

        .btn-outline {
            background: transparent;
            color: white;
            text-decoration: none;
            padding: 0.85rem 2rem;
            border-radius: 50px;
            font-weight: 600;
            font-size: 1rem;
            border: 1.5px solid rgba(255,255,255,0.5);
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }

        .btn-outline:hover {
            border-color: white;
            background: rgba(255,255,255,0.1);
            transform: translateY(-3px);
        }

        /* ======= STATS BAR ======= */
        .stats-bar {
            background: white;
            border-bottom: 1px solid #eee;
            padding: 1.2rem 2rem;
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1rem;
            max-width: 900px;
            margin: 0 auto;
            border-radius: 0 0 var(--radius) var(--radius);
            box-shadow: 0 8px 30px rgba(0,0,0,0.08);
            position: relative;
            z-index: 5;
        }

        .stat-item {
            text-align: center;
            padding: 0.5rem;
            border-left: 1px solid #eee;
        }

        .stat-item:last-child { border-left: none; }

        .stat-num {
            font-size: 1.6rem;
            font-weight: 900;
            color: var(--primary-dark);
            line-height: 1;
        }

        .stat-num span { color: var(--gold); }

        .stat-label {
            font-size: 0.8rem;
            color: #888;
            margin-top: 2px;
        }

        /* ======= WRAPPER ======= */
        .wrapper {
            max-width: 1200px;
            margin: 3rem auto 4rem;
            background: white;
            border-radius: 30px;
            padding: clamp(2rem, 5vw, 4rem);
            box-shadow: var(--card-shadow);
            position: relative;
        }

        /* ======= SECTION HEADERS ======= */
        .section-header {
            text-align: center;
            margin-bottom: 3.5rem;
        }

        .section-tag {
            display: inline-block;
            background: var(--gold-dim);
            color: var(--gold);
            border: 1px solid var(--gold);
            padding: 4px 14px;
            border-radius: 50px;
            font-size: 0.8rem;
            font-weight: 700;
            letter-spacing: 1.5px;
            margin-bottom: 1rem;
            text-transform: uppercase;
        }

        .section-header h2 {
            color: var(--primary-dark);
            font-size: clamp(1.7rem, 4vw, 2.6rem);
            font-weight: 900;
            font-family: 'Amiri', serif;
            position: relative;
            display: inline-block;
            line-height: 1.2;
        }

        .section-header h2::after {
            content: '';
            display: block;
            width: 50%;
            height: 3px;
            background: linear-gradient(90deg, var(--gold) 0%, transparent 100%);
            margin: 10px auto 0;
            border-radius: 2px;
        }

        .section-header p {
            color: #777;
            font-size: 1.05rem;
            margin-top: 1rem;
            max-width: 550px;
            margin-left: auto;
            margin-right: auto;
        }

        /* ======= ITINERARY ======= */
        .itinerary { margin-top: 2rem; }

        .day-block {
            margin-bottom: 3.5rem;
            border-right: 5px solid var(--primary-dark);
            padding-right: 2rem;
            position: relative;
        }

        .day-block::before {
            content: '';
            position: absolute;
            right: -10px;
            top: 0;
            width: 16px;
            height: 16px;
            background: var(--gold);
            border-radius: 50%;
            border: 3px solid white;
            box-shadow: 0 0 0 3px var(--primary-dark);
        }

        .day-block:nth-child(2) { border-right-color: var(--gold); }
        .day-block:nth-child(2)::before { background: var(--primary-dark); }

        .day-num {
            background: linear-gradient(135deg, var(--primary-dark), var(--primary-mid));
            color: var(--gold);
            padding: 10px 22px;
            border-radius: 50px;
            font-weight: 700;
            font-size: 1rem;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 1.5rem;
            box-shadow: 0 4px 15px rgba(11,35,24,0.2);
        }

        .slot {
            display: grid;
            grid-template-columns: 110px 1fr;
            gap: 1.5rem;
            align-items: flex-start;
            padding: 14px 16px;
            border-radius: 12px;
            margin-bottom: 8px;
            transition: background 0.2s;
        }

        .slot:hover { background: #f8f9f7; }

        .slot-time {
            font-weight: 700;
            color: var(--gold);
            font-size: 1.1rem;
            padding-left: 1rem;
            border-left: 2px solid #eee;
        }

        .slot-content { font-size: 1rem; color: var(--text-mid); }
        .slot-content b { color: var(--primary-dark); }

        /* ======= CARDS ======= */
        .info-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.5rem;
            margin-top: 3rem;
        }

        .card-dark {
            background: linear-gradient(145deg, var(--primary-dark), var(--primary-mid));
            color: white;
            padding: 2.5rem;
            border-radius: var(--radius);
            border: 1px solid rgba(200,164,90,0.2);
            box-shadow: var(--card-shadow);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .card-dark::before {
            content: '';
            position: absolute;
            top: -40px;
            left: -40px;
            width: 160px;
            height: 160px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(200,164,90,0.15), transparent 70%);
        }

        .card-dark:hover {
            transform: translateY(-6px);
            box-shadow: 0 30px 70px rgba(11,35,24,0.25);
        }

        .card-dark h3 {
            color: var(--gold);
            font-family: 'Amiri', serif;
            font-size: 1.6rem;
            margin-bottom: 0.75rem;
            position: relative;
            z-index: 1;
        }

        .price-display {
            font-size: 3.5rem;
            font-weight: 900;
            display: block;
            background: linear-gradient(135deg, var(--gold), var(--gold-light));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            line-height: 1.1;
            margin: 0.5rem 0;
            position: relative;
            z-index: 1;
        }

        .price-display sup {
            font-size: 1.2rem;
            font-weight: 400;
            -webkit-text-fill-color: var(--gold);
        }

        .card-dark p {
            position: relative;
            z-index: 1;
            opacity: 0.9;
            font-size: 0.95rem;
            margin-top: 0.75rem;
        }

        .card-light {
            background: var(--gray-bg);
            padding: 2.5rem;
            border-radius: var(--radius);
            border-right: 6px solid var(--gold);
            box-shadow: 0 8px 25px rgba(0,0,0,0.06);
            transition: transform 0.3s ease;
        }

        .card-light:hover { transform: translateY(-6px); }

        .card-light h3 {
            color: var(--primary-dark);
            font-family: 'Amiri', serif;
            font-size: 1.5rem;
            margin-bottom: 1.2rem;
        }

        /* ======= SPECS LIST ======= */
        .specs-list { list-style: none; }

        .specs-list li {
            padding: 10px 0 10px 0;
            position: relative;
            font-size: 0.97rem;
            color: var(--text-mid);
            border-bottom: 1px solid rgba(0,0,0,0.05);
            display: flex;
            align-items: flex-start;
            gap: 10px;
        }

      .specs-list li:last-child { border-bottom: none; }

        .specs-list li::before {
            content: '✓';
            color: var(--gold);
            font-weight: 900;
            font-size: 1rem;
            flex-shrink: 0;
            margin-top: 1px;
        }

        .specs-list li b { color: var(--primary-dark); }

        /* ======= COMMUNITY SECTION ======= */
        .community-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 1.5rem;
            margin-top: 2rem;
        }

        .community-card {
            background: white;
            padding: 2rem;
            border-radius: var(--radius);
            border-top: 4px solid var(--gold);
            box-shadow: 0 8px 25px rgba(0,0,0,0.07);
            transition: transform 0.3s;
        }

        .community-card:nth-child(2) { border-top-color: var(--success); }

        .community-card:hover { transform: translateY(-6px); }

        .community-card h3 {
            color: var(--primary-dark);
            font-family: 'Amiri', serif;
            font-size: 1.35rem;
            margin-bottom: 0.75rem;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .community-card h3 i { color: var(--gold); }

        .community-card:nth-child(2) h3 i { color: var(--success); }

        .community-card p { font-size: 0.95rem; color: #666; margin-bottom: 1rem; }

        /* ======= APP SECTION ======= */
        .app-section {
            margin-top: 4rem;
            padding-top: 3rem;
            border-top: 1px solid #eee;
        }

        .app-mockup {
            position: relative;
            width: 100%;
            height: 420px;
            background: url('https://images.unsplash.com/photo-1524661135-423995f22d0b?q=80&w=1200') center/cover;
            border-radius: var(--radius);
            overflow: hidden;
            box-shadow: var(--card-shadow);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .app-mockup::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(11,35,24,0.85) 0%, rgba(11,35,24,0.6) 100%);
        }

        .app-content {
            position: relative;
            z-index: 2;
            text-align: center;
            color: white;
            padding: 2rem;
        }

        .app-icon {
            width: 70px;
            height: 70px;
            background: var(--gold-dim);
            border: 2px solid var(--gold);
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.2rem;
            font-size: 2rem;
            color: var(--gold);
            animation: pulse 3s ease-in-out infinite;
        }

        @keyframes pulse {
            0%, 100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(200,164,90,0.3); }
            50% { transform: scale(1.05); box-shadow: 0 0 0 12px rgba(200,164,90,0); }
        }

        .app-content h3 {
            font-family: 'Amiri', serif;
            font-size: 2rem;
            margin-bottom: 1rem;
        }

        .app-features {
            list-style: none;
            display: inline-block;
            text-align: right;
            font-size: 1rem;
        }

        .app-features li {
            padding: 5px 0;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .app-features li i { color: var(--gold); }

        /* ======= BOOKING FORM ======= */
        .booking-section {
            background: linear-gradient(135deg, #eef1ee 0%, #dde4dd 100%);
            padding: 4rem 2rem;
            border-radius: var(--radius);
            margin-top: 3rem;
        }

        .booking-container {
            max-width: 820px;
            margin: 0 auto;
            background: white;
            border-radius: var(--radius);
            box-shadow: var(--card-shadow);
            overflow: hidden;
        }

        .booking-header {
            background: linear-gradient(135deg, var(--primary-dark), var(--primary-mid));
            padding: 2rem 2.5rem;
            text-align: center;
            border-bottom: 3px solid var(--gold);
        }

        .booking-header h2 {
            color: var(--gold);
            font-family: 'Amiri', serif;
            font-size: 1.9rem;
            margin-bottom: 0.25rem;
        }

        .booking-header p { color: rgba(255,255,255,0.75); font-size: 0.95rem; }

        .booking-body { padding: 2.5rem; }

        .form-section {
            margin-bottom: 2rem;
            padding-bottom: 2rem;
            border-bottom: 1px solid #eee;
        }

        .form-section:last-of-type { border-bottom: none; margin-bottom: 0; }

        .form-section-title {
            display: flex;
            align-items: center;
            gap: 8px;
            color: var(--primary-dark);
            font-size: 1.1rem;
            font-weight: 700;
            margin-bottom: 1.2rem;
        }

        .form-section-title i { color: var(--gold); }

        .form-group { margin-bottom: 1.2rem; }

        .form-group label {
            display: block;
            color: var(--primary-dark);
            font-weight: 600;
            font-size: 0.9rem;
            margin-bottom: 6px;
        }

        .input-wrapper {
            position: relative;
            display: flex;
            align-items: center;
        }

        .input-icon {
            position: absolute;
            right: 14px;
            color: var(--gold);
            font-size: 1rem;
            pointer-events: none;
            z-index: 1;
        }

        .form-group input,
        .form-group textarea,
        .form-group select {
            width: 100%;
            padding: 11px 40px 11px 14px;
            border: 1.5px solid #ddd;
            border-radius: 10px;
            font-family: 'Cairo', sans-serif;
            font-size: 0.97rem;
            color: var(--text-dark);
            background: white;
            transition: border-color 0.25s, box-shadow 0.25s;
            appearance: none;
            -webkit-appearance: none;
        }

        .form-group input:focus,
        .form-group textarea:focus,
        .form-group select:focus {
            outline: none;
            border-color: var(--gold);
            box-shadow: 0 0 0 3px rgba(200,164,90,0.12);
        }

        /* Validation states */
        .form-group input:invalid:not(:placeholder-shown),
        .form-group select:invalid:not([value=""]) {
            border-color: var(--error);
        }

        .form-group input:valid:not(:placeholder-shown) {
            border-color: var(--success);
        }

        .form-group textarea {
            resize: vertical;
            min-height: 90px;
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
        }

        /* Price Summary */
        .price-summary {
            background: linear-gradient(135deg, var(--primary-dark), var(--primary-mid));
            color: white;
            padding: 1.5rem 2rem;
            border-radius: 14px;
            margin: 1.5rem 0;
        }

        .price-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 8px 0;
            font-size: 0.97rem;
            border-bottom: 1px solid rgba(255,255,255,0.08);
        }

        .price-row:last-child {
            border-bottom: none;
            padding-top: 12px;
            font-size: 1.2rem;
            font-weight: 700;
            color: var(--gold);
        }

        .price-row i { margin-left: 6px; color: var(--gold); font-size: 0.9rem; }
        .price-row strong { font-weight: 600; }
        .price-row:last-child strong { color: var(--gold); font-weight: 900; font-size: 1.3rem; }

        /* Terms */
        .terms-box {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            padding: 14px 16px;
            background: #f8f9f7;
            border-radius: 10px;
            margin: 1.2rem 0;
        }

        .terms-box input[type="checkbox"] {
            width: 18px;
            height: 18px;
            accent-color: var(--primary-dark);
            cursor: pointer;
            flex-shrink: 0;
            margin-top: 2px;
            padding: 0;
            border: none;
        }

        .terms-box label {
            cursor: pointer;
            font-size: 0.9rem;
            color: #555;
        }

        .terms-box a {
            color: var(--gold);
            text-decoration: none;
            font-weight: 600;
        }

        /* Submit Button */
        .submit-btn {
            width: 100%;
            background: linear-gradient(135deg, var(--primary-dark), var(--primary-mid));
            color: white;
            border: none;
            padding: 1rem 2rem;
            border-radius: 12px;
            font-family: 'Cairo', sans-serif;
            font-size: 1.1rem;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            box-shadow: 0 6px 20px rgba(11,35,24,0.25);
            border: 1px solid rgba(200,164,90,0.3);
        }

        .submit-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 30px rgba(11,35,24,0.35);
            background: linear-gradient(135deg, #0d2a1c, #1a4a30);
        }

        .submit-btn:active { transform: translateY(0); }

        .submit-btn i { color: var(--gold); }

        /* Error/Success messages */
        .field-error {
            color: var(--error);
            font-size: 0.82rem;
            margin-top: 4px;
            display: none;
        }

        .field-error.visible { display: block; }

        /* ======= FOOTER ======= */
        footer {
            background: linear-gradient(135deg, var(--primary-dark), var(--primary-mid));
            color: white;
            padding: 3.5rem 2rem;
            text-align: center;
            border-top: 4px solid var(--gold);
        }

        .footer-logo {
            font-family: 'Amiri', serif;
            font-size: 2.2rem;
            color: var(--gold);
            margin-bottom: 0.75rem;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        footer p {
            margin: 6px 0;
            opacity: 0.85;
            font-size: 0.95rem;
        }

        footer p b { color: var(--gold); }

        .footer-contact {
            margin: 1rem 0;
            font-size: 1.05rem;
            font-weight: 600;
            color: var(--gold);
        }

        .footer-social {
            margin-top: 1.5rem;
            display: flex;
            gap: 12px;
            justify-content: center;
        }

        .social-btn {
            width: 42px;
            height: 42px;
            background: rgba(200,164,90,0.15);
            color: var(--gold);
            border: 1px solid rgba(200,164,90,0.4);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            font-size: 1rem;
            transition: all 0.25s;
        }

        .social-btn:hover {
            background: var(--gold);
            color: var(--primary-dark);
            transform: translateY(-3px);
        }

        /* ======= NOTIFICATIONS ======= */
        #toast {
            position: fixed;
            bottom: 24px;
            left: 24px;
            background: var(--primary-dark);
            color: white;
            padding: 14px 22px;
            border-radius: 12px;
            border-right: 4px solid var(--gold);
            font-size: 0.95rem;
            font-weight: 600;
            z-index: 9999;
            box-shadow: 0 8px 25px rgba(0,0,0,0.25);
            display: flex;
            align-items: center;
            gap: 10px;
            transform: translateY(100px);
            opacity: 0;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            pointer-events: none;
        }

        #toast.show {
            transform: translateY(0);
            opacity: 1;
        }

        #toast i { color: var(--gold); }

        /* ======= SCROLL TO TOP ======= */
        #scrollTop {
            position: fixed;
            bottom: 24px;
            right: 24px;
            width: 44px;
            height: 44px;
            background: var(--primary-dark);
            color: var(--gold);
            border: 1px solid rgba(200,164,90,0.4);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 1rem;
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
            transition: all 0.3s;
            opacity: 0;
            pointer-events: none;
            z-index: 999;
        }

        #scrollTop.visible { opacity: 1; pointer-events: auto; }
        #scrollTop:hover { transform: translateY(-3px); background: var(--gold); color: var(--primary-dark); }

        /* ======= ANIMATIONS ======= */
        @keyframes fadeInDown {
            from { opacity: 0; transform: translateY(-20px); }
            to { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .reveal {
            opacity: 0;
            transform: translateY(25px);
            transition: opacity 0.6s ease, transform 0.6s ease;
        }

        .reveal.visible {
            opacity: 1;
            transform: translateY(0);
        }

        /* ======= RESPONSIVE ======= */
        @media (max-width: 900px) {
            .stats-bar { grid-template-columns: repeat(2, 1fr); }
        }

        @media (max-width: 768px) {
            .menu-icon { display: block; }

            .nav-menu {
                position: absolute;
                top: 100%;
                right: 0;
                left: 0;
                flex-direction: column;
                background: var(--primary-dark);
                border-top: 2px solid var(--gold-dim);
                padding: 0.5rem 0;
                display: none;
                gap: 0;
            }

            .nav-menu.open { display: flex; }
            .nav-link { padding: 0.9rem 1.5rem; border-radius: 0; font-size: 1rem; }

            .info-grid { grid-template-columns: 1fr; }
            .form-row { grid-template-columns: 1fr; }
            .slot { grid-template-columns: 90px 1fr; gap: 1rem; }

            header { background-attachment: scroll; min-height: 60vh; }
        }

        @media (max-width: 540px) {
            .stats-bar { grid-template-columns: repeat(2, 1fr); border-radius: 0; }
            .stat-item { border-left: none; border-bottom: 1px solid #eee; }
        }
    </style>
</head>
